project        = "myapp"
environment    = "prod"
aws_region     = "us-east-1"
aws_account_id = "123456789012"

alert_email = "oncall@example.com"

container_image = "123456789012.dkr.ecr.us-east-1.amazonaws.com/myapp-prod:latest"

enable_https        = true
acm_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/REPLACE_WITH_CERT_ID"

github_org           = "your-github-org"
github_repo          = "saas-backend-infra-on-aws"
create_oidc_provider = false
